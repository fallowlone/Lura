  #border:  #cccccc
})

PAGE(
  H2({color: #accent} Telefonica Germany GmbH und Co. OHG)
  P({color: #muted, font-size: 9} Georg-Brauchle-Ring 50  80992 München  |  o2online.de/service/  |  089 78 79 79 40 0)

  H1({color: #brand} Vertragszusammenfassung)
  P({color: #muted, font-size: 9} o2 Home L 250  -  12.03.2026)

  P({font-size: 9} Diese Vertragszusammenfassung enthält die Hauptbestandteile dieses Dienstleistungsangebots, wie es das EU-Recht vorschreibt.)
  P({font-size: 9} Sie erleichtert den Vergleich verschiedener Angebote.)
  P({font-size: 9} Vollständige Information über die Dienstleistung sind in anderen Dokumenten enthalten.)

  H2({color: #accent} Dienste und Geräte)
  P({font-size: 9} Sprachtelefonanschluss mit Flatrate für Gespräche ins deutsche Fest- und Mobilfunknetz, Internetzugang mit unbegrenztem Datenvolumen. Die Dienste sind nur an der vereinbarten festen Anschlussadresse nutzbar.)

  H2({color: #accent} Geschwindigkeiten des Internetdienstes)
  P({font-size: 9} Bei Bereitstellung über DSL und Glasfaser: Maximale und beworbene Datengeschwindigkeit 250 MBit/s im Download und 40 MBit/s im Upload, minimale 175 MBit/s im Download und 20 MBit/s im Upload, normalerweise 200 MBit/s im Download und 35 MBit/s im Upload.)
  P({font-size: 9} Bei Bereitstellung über Kabel: Maximale 250 MBit/s im Download und 10 MBit/s im Upload, minimale 105 MBit/s im Download und 3 MBit/s im Upload, normalerweise 200 MBit/s im Download und 7 MBit/s im Upload.)
  P({font-size: 9} Im Falle einer Abweichung der Geschwindigkeit können Sie unter den Voraussetzungen des TKG das Recht auf Minderung und Kündigung geltend machen.)

  H2({color: #accent} Entgelte)
  TABLE(
